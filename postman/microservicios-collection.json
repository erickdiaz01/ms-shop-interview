  "item": [
    {
      "name": "\ud83d\udd10 Autenticacion (Keycloak)",
      "item": [
        {
          "name": "01 - Login (Resource Owner Password)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Guardar tokens automaticamente como variables de coleccion",
                  "var body = pm.response.json();",
                  "if (body.access_token) {",
                  "    pm.collectionVariables.set('jwt_token', body.access_token);",
                  "    pm.collectionVariables.set('refresh_token', body.refresh_token);",
                  "    console.log('\u2705 Token guardado. Expira en: ' + body.expires_in + 's');",
                  "    pm.test('Login exitoso', () => pm.response.to.have.status(200));",
                  "} else {",
                  "    pm.test('Login FALLIDO', () => { throw new Error(JSON.stringify(body)); });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "password",
                  "type": "text"
                },
                {
                  "key": "client_id",
                  "value": "{{client_id}}",
                  "type": "text"
                },
                {
                  "key": "client_secret",
                  "value": "{{client_secret}}",
                  "type": "text"
                },
                {
                  "key": "username",
                  "value": "{{username}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "{{password}}",
                  "type": "text"
                },
                {
                  "key": "scope",
                  "value": "openid profile email",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{keycloak_url}}/realms/{{realm}}/protocol/openid-connect/token",
              "host": [
                "{{keycloak_url}}"
              ],
              "path": [
                "realms",
                "{{realm}}",
                "protocol",
                "openid-connect",
                "token"
              ]
            },
            "description": "Obtiene un JWT usando username/password. El token se guarda automaticamente en la variable 'jwt_token'.\n\nCambia {{username}} y {{password}} en las variables para usar otro usuario."
          }
        },
        {
          "name": "02 - Login Admin (ROLE_ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var body = pm.response.json();",
                  "if (body.access_token) { pm.collectionVariables.set('jwt_token', body.access_token); console.log('\u2705 Admin token guardado'); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "password"
                },
                {
                  "key": "client_id",
                  "value": "{{client_id}}"
                },
                {
                  "key": "client_secret",
                  "value": "{{client_secret}}"
                },
                {
                  "key": "username",
                  "value": "admin@test.com"
                },
                {
                  "key": "password",
                  "value": "admin123"
                },
                {
                  "key": "scope",
                  "value": "openid"
                }
              ]
            },
            "url": {
              "raw": "{{keycloak_url}}/realms/{{realm}}/protocol/openid-connect/token",
              "host": [
                "{{keycloak_url}}"
              ],
              "path": [
                "realms",
                "{{realm}}",
                "protocol",
                "openid-connect",
                "token"
              ]
            }
          }
        },
        {
          "name": "03 - Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var body = pm.response.json();",
                  "if (body.access_token) { pm.collectionVariables.set('jwt_token', body.access_token); pm.collectionVariables.set('refresh_token', body.refresh_token); console.log('\u2705 Token renovado'); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "refresh_token"
                },
                {
                  "key": "client_id",
                  "value": "{{client_id}}"
                },
                {
                  "key": "client_secret",
                  "value": "{{client_secret}}"
                },
                {
                  "key": "refresh_token",
                  "value": "{{refresh_token}}"
                }
              ]
            },
            "url": {
              "raw": "{{keycloak_url}}/realms/{{realm}}/protocol/openid-connect/token",
              "host": [
                "{{keycloak_url}}"
              ],
              "path": [
                "realms",
                "{{realm}}",
                "protocol",
                "openid-connect",
                "token"
              ]
            }
          }
        },
        {
          "name": "04 - Introspect Token (ver claims)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "client_id",
                  "value": "{{client_id}}"
                },
                {
                  "key": "client_secret",
                  "value": "{{client_secret}}"
                },
                {
                  "key": "token",
                  "value": "{{jwt_token}}"
                }
              ]
            },
            "url": {
              "raw": "{{keycloak_url}}/realms/{{realm}}/protocol/openid-connect/token/introspect",
              "host": [
                "{{keycloak_url}}"
              ],
              "path": [
                "realms",
                "{{realm}}",
                "protocol",
                "openid-connect",
                "token",
                "introspect"
              ]
            },
            "description": "Muestra todos los claims del token: sub, realm_access.roles, exp, etc."
          }
        },
        {
          "name": "05 - Client Credentials (machine-to-machine)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var body = pm.response.json();",
                  "if (body.access_token) { pm.collectionVariables.set('jwt_token', body.access_token); console.log('\u2705 Service token (client credentials)'); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "client_credentials"
                },
                {
                  "key": "client_id",
                  "value": "{{client_id}}"
                },
                {
                  "key": "client_secret",
                  "value": "{{client_secret}}"
                }
              ]
            },
            "url": {
              "raw": "{{keycloak_url}}/realms/{{realm}}/protocol/openid-connect/token",
              "host": [
                "{{keycloak_url}}"
              ],
              "path": [
                "realms",
                "{{realm}}",
                "protocol",
                "openid-connect",
                "token"
              ]
            },
            "description": "Obtiene token sin usuario (client credentials). Util para servicios automatizados."
          }
        }
      ]
    },
